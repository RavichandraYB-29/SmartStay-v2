rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ───────── COMMON HELPERS ───────── */

    function isSignedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userDoc() {
      return get(userPath());
    }

    function userExists() {
      return exists(userPath());
    }

    function adminPath() {
      return /databases/$(database)/documents/admins/$(request.auth.uid);
    }

    function adminExists() {
      return exists(adminPath());
    }

    function isAdmin() {
      return isSignedIn() &&
        (
          (userExists() && userDoc().data.role == 'admin') ||
          adminExists()
        );
    }

    function isResident() {
      return isSignedIn()
        && userExists()
        && userDoc().data.role == 'resident';
    }

    /* ───────── RESIDENT HELPERS ───────── */

    function residentPathForUser() {
      return /databases/$(database)/documents/residents/$(userDoc().data.residentId);
    }

    function residentDocForUser() {
      return get(residentPathForUser());
    }

    function hasResidentRecord() {
      return isResident()
        && userDoc().data.residentId != null
        && exists(residentPathForUser());
    }

    /* ───────── HOSTEL HELPERS ───────── */

    function hostelPath(hostelId) {
      return /databases/$(database)/documents/hostels/$(hostelId);
    }

    function isHostelAdmin(hostelId) {
      let hostel = get(hostelPath(hostelId));
      return isAdmin()
        && exists(hostelPath(hostelId))
        && (
          hostel.data.adminId == request.auth.uid ||
          (hostel.data.ownerId != null && hostel.data.ownerId == request.auth.uid)
        );
    }

    function isHostelOwner(hostelId) {
      let hostel = get(hostelPath(hostelId));
      return isSignedIn()
        && exists(hostelPath(hostelId))
        && (
          hostel.data.adminId == request.auth.uid ||
          (hostel.data.ownerId != null && hostel.data.ownerId == request.auth.uid)
        );
    }

    /* ───────── ASSIGNMENT HELPERS ───────── */

    function isAssignedToPg(hostelId, pgId) {
      return isResident()
        && hasResidentRecord()
        && residentDocForUser().data.isAllocated == true
        && (
          (residentDocForUser().data.allocationDetails != null
            ? residentDocForUser().data.allocationDetails.hostelId
            : residentDocForUser().data.hostelId) == hostelId
        )
        && (
          (residentDocForUser().data.allocationDetails != null
            ? residentDocForUser().data.allocationDetails.pgId
            : residentDocForUser().data.pgId) == pgId
        )
    }

    function isAssignedToRoom(hostelId, pgId, floorId, roomId) {
      return isResident()
        && hasResidentRecord()
        && residentDocForUser().data.isAllocated == true
        && (
          (residentDocForUser().data.allocationDetails != null
            ? residentDocForUser().data.allocationDetails.hostelId
            : residentDocForUser().data.hostelId) == hostelId
        )
        && (
          (residentDocForUser().data.allocationDetails != null
            ? residentDocForUser().data.allocationDetails.pgId
            : residentDocForUser().data.pgId) == pgId
        )
        && (
          (residentDocForUser().data.allocationDetails != null
            ? residentDocForUser().data.allocationDetails.floorId
            : residentDocForUser().data.floorId) == floorId
        )
        && (
          (residentDocForUser().data.allocationDetails != null
            ? residentDocForUser().data.allocationDetails.roomId
            : residentDocForUser().data.roomId) == roomId
        );
    }

    /* ───────── GENERIC OWNERSHIP ───────── */

    function isAdminOwner(data) {
      return isAdmin() &&
        (
          data.adminId == request.auth.uid ||
          (data.ownerId != null && data.ownerId == request.auth.uid)
        );
    }

    function isOwner(data) {
      return isSignedIn() &&
        (
          data.adminId == request.auth.uid ||
          (data.ownerId != null && data.ownerId == request.auth.uid)
        );
    }

    function isSelf(data) {
      return isSignedIn() && data.userId == request.auth.uid;
    }

    /* ───────── USERS ───────── */

    match /users/{userId} {
      allow create: if isSignedIn()
        && userId == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && (request.resource.data.role == 'admin'
          || request.resource.data.role == 'resident');

      allow read, update: if isSignedIn() && userId == request.auth.uid;
    }

    /* ───────── HOSTELS ───────── */

    match /hostels/{hostelId} {
      allow create: if isAdmin()
        && request.resource.data.adminId == request.auth.uid;

      allow read: if isAdmin() || isHostelOwner(hostelId);

      allow update, delete: if isAdminOwner(resource.data);

      match /pgs/{pgId} {
        allow create, update, delete: if isHostelAdmin(hostelId);

        allow read: if isAdmin()
          || isHostelOwner(hostelId)
          || isAssignedToPg(hostelId, pgId);

        match /floors/{floorId} {
          allow create, update, delete: if isHostelAdmin(hostelId);

          allow read: if isAdmin()
            || isHostelOwner(hostelId)
            || isAssignedToPg(hostelId, pgId);

          match /rooms/{roomId} {
            allow create, update, delete: if isHostelAdmin(hostelId);

            allow read: if isAdmin()
              || isHostelOwner(hostelId)
              || isAssignedToRoom(hostelId, pgId, floorId, roomId);

            match /beds/{bedId} {
              allow create: if isHostelAdmin(hostelId);

              allow update: if isHostelAdmin(hostelId)
                && request.resource.data.diff(resource.data).changedKeys()
                  .hasOnly(['isOccupied', 'occupiedBy', 'residentId']);

              allow delete: if isHostelAdmin(hostelId);

              allow read: if isAdmin()
                || isHostelOwner(hostelId)
                || isAssignedToRoom(hostelId, pgId, floorId, roomId);
            }
          }
        }
      }
    }

    /* ───────── RESIDENTS (ADMIN-CREATED AUTH + VERIFY FLOW) ───────── */

    match /residents/{residentId} {

      // Admin creates resident + auth link
      allow create: if isAdmin()
        && request.resource.data.adminId == request.auth.uid
        && request.resource.data.role == 'resident'
        && request.resource.data.status == 'invited'
        && request.resource.data.isEmailVerified == false
        && request.resource.data.isAllocated == false
        && request.resource.data.uid == null
        && request.resource.data.authUid != null;

      // Admin / owner access
      allow read, update, delete: if isAdminOwner(resource.data)
        || isOwner(resource.data)
        || (
          resource.data.hostelId != null
          && isHostelAdmin(resource.data.hostelId)
        );

      // Resident reads own record (authUid)
      allow read: if isSignedIn()
        && resource.data.authUid == request.auth.uid;

      // Resident activates after verification
      allow update: if isSignedIn()
        && resource.data.authUid == request.auth.uid
        && request.resource.data.authUid == request.auth.uid
        && request.resource.data.status == 'active'
        && request.resource.data.isEmailVerified == true
        && request.resource.data.adminId == resource.data.adminId
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(['status', 'isEmailVerified', 'authUid']);
    }

    /* ───────── COMPLAINTS ───────── */

    match /complaints/{complaintId} {
      allow create: if isSignedIn() && isSelf(request.resource.data);
      allow read, update, delete: if isAdminOwner(resource.data)
        || isOwner(resource.data)
        || isSelf(resource.data);
    }

    /* ───────── PAYMENTS ───────── */

    match /payments/{paymentId} {
      allow create, update, delete: if isAdminOwner(request.resource.data);
      allow read: if isAdminOwner(resource.data)
        || isOwner(resource.data)
        || isSelf(resource.data);
    }

    /* ───────── NOTICES ───────── */

    match /notices/{noticeId} {
      allow create: if isAdmin()
        && request.resource.data.createdByAdminId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.message is string
        && request.resource.data.noticeType is string
        && request.resource.data.scope in ['ALL', 'PG', 'RESIDENT']
        && request.resource.data.pgIds is list
        && request.resource.data.residentIds is list
        && request.resource.data.isActive is bool;

      allow update, delete: if isAdmin()
        && resource.data.createdByAdminId == request.auth.uid;

      allow read: if isAdmin()
        || (
          hasResidentRecord()
          && (
            resource.data.isActive == true
            && (
              resource.data.scope == 'ALL'
              && resource.data.pgIds.hasAny([
                (residentDocForUser().data.allocationDetails != null
                  ? residentDocForUser().data.allocationDetails.pgId
                  : residentDocForUser().data.pgId
                )
              ])
            )
            || (
              resource.data.scope == 'PG'
              && resource.data.pgIds.hasAny([
                (residentDocForUser().data.allocationDetails != null
                  ? residentDocForUser().data.allocationDetails.pgId
                  : residentDocForUser().data.pgId
                )
              ])
            )
            || (
              resource.data.scope == 'RESIDENT'
              && resource.data.residentIds.hasAny([userDoc().data.residentId])
            )
          )
        );
    }
  }
}
