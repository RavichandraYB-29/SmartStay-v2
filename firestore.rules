rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ───────── COMMON HELPERS ───────── */

    function isSignedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userDoc() {
      return get(userPath());
    }

    function userExists() {
      return exists(userPath());
    }

    function adminPath() {
      return /databases/$(database)/documents/admins/$(request.auth.uid);
    }

    function adminExists() {
      return exists(adminPath());
    }

    function isAdmin() {
      return isSignedIn()
        && (
          (userExists() && userDoc().data.role == 'admin')
          || adminExists()
        );
    }

    function isResident() {
      return isSignedIn()
        && userExists()
        && userDoc().data.role == 'resident';
    }

    /* ───────── RESIDENT HELPERS ───────── */

    function residentPathForUser() {
      return /databases/$(database)/documents/residents/$(userDoc().data.residentId);
    }

    function residentDocForUser() {
      return get(residentPathForUser());
    }

    function hasResidentRecord() {
      return isResident()
        && userDoc().data.residentId != null
        && exists(residentPathForUser());
    }

    /* ───────── HOSTEL HELPERS ───────── */

    function hostelPath(hostelId) {
      return /databases/$(database)/documents/hostels/$(hostelId);
    }

    function isHostelAdmin(hostelId) {
      let hostel = get(hostelPath(hostelId));
      return isAdmin()
        && exists(hostelPath(hostelId))
        && (
          hostel.data.adminId == request.auth.uid ||
          (hostel.data.ownerId != null && hostel.data.ownerId == request.auth.uid)
        );
    }


    function isHostelOwner(hostelId) {
      let hostel = get(hostelPath(hostelId));
      return isSignedIn()
        && exists(hostelPath(hostelId))
        && (
          hostel.data.adminId == request.auth.uid ||
          (hostel.data.ownerId != null && hostel.data.ownerId == request.auth.uid)
        );
    }

    /* ───────── ASSIGNMENT HELPERS (UNCHANGED) ───────── */

    function isAssignedToHostel(hostelId) {
      return isResident()
        && hasResidentRecord()
        && residentDocForUser().data.isAllocated == true
        && (
          (residentDocForUser().data.allocationDetails != null
              ? residentDocForUser().data.allocationDetails.hostelId
              : residentDocForUser().data.hostelId) == hostelId
        );
    }

    function isAssignedToRoom(hostelId, floorId, roomId) {
      return isResident()
        && hasResidentRecord()
        && residentDocForUser().data.isAllocated == true
        && (
          (residentDocForUser().data.allocationDetails != null
              ? residentDocForUser().data.allocationDetails.hostelId
              : residentDocForUser().data.hostelId) == hostelId
        )
        && (
          (residentDocForUser().data.allocationDetails != null
              ? residentDocForUser().data.allocationDetails.floorId
              : residentDocForUser().data.floorId) == floorId
        )
        && (
          (residentDocForUser().data.allocationDetails != null
              ? residentDocForUser().data.allocationDetails.roomId
              : residentDocForUser().data.roomId) == roomId
        );
    }

    /* ───────── GENERIC OWNERSHIP ───────── */

    function isAdminOwner(data) {
      return isAdmin() && (
        data.adminId == request.auth.uid ||
        (data.ownerId != null && data.ownerId == request.auth.uid)
      );
    }

    function isOwner(data) {
      return isSignedIn() && (
        data.adminId == request.auth.uid ||
        (data.ownerId != null && data.ownerId == request.auth.uid)
      );
    }

    function isSelf(data) {
      return isSignedIn() && data.userId == request.auth.uid;
    }

    /* ───────── USERS ───────── */

    match /users/{userId} {
      allow create: if isSignedIn()
        && userId == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && (request.resource.data.role == 'admin'
          || request.resource.data.role == 'resident');
      allow read: if isSignedIn() && userId == request.auth.uid;
      allow update: if isSignedIn()
        && userId == request.auth.uid
        && request.resource.data.role == resource.data.role
        && request.resource.data.email == request.auth.token.email;
    }

    /* ───────── HOSTELS ───────── */

    match /hostels/{hostelId} {
      allow create: if isAdmin()
        && request.resource.data.adminId == request.auth.uid;

      allow read: if isOwner(resource.data)
        || isAssignedToHostel(hostelId);

      allow update, delete: if isAdminOwner(resource.data);

      match /floors/{floorId} {
        allow create, update, delete: if isHostelAdmin(hostelId);
        allow read: if isHostelOwner(hostelId)
          || isAssignedToHostel(hostelId);

        match /rooms/{roomId} {
          allow create, update, delete: if isHostelAdmin(hostelId);
          allow read: if isHostelOwner(hostelId)
            || isAssignedToRoom(hostelId, floorId, roomId);

          match /beds/{bedId} {
            allow create: if isHostelAdmin(hostelId);
            allow update: if isHostelAdmin(hostelId)
              && request.resource.data.diff(resource.data).changedKeys()
                .hasOnly(['isOccupied', 'occupiedBy', 'residentId']);
            allow delete: if isHostelAdmin(hostelId);
            allow read: if isHostelOwner(hostelId)
              || isAssignedToRoom(hostelId, floorId, roomId);
          }
        }
      }
    }

    /* ───────── RESIDENTS (FIXED FOR QUERY COMPATIBILITY) ───────── */

    match /residents/{residentId} {

      // Admin creates resident invite
      allow create: if isAdmin()
        && request.resource.data.adminId == request.auth.uid
        && request.resource.data.status == 'invited'
        && request.resource.data.isAllocated == false
        && request.resource.data.uid == null;

      // Admin / owner full control
      allow read, update, delete: if isAdminOwner(resource.data)
        || isOwner(resource.data)
        || (
          resource.data.hostelId != null
          && isHostelAdmin(resource.data.hostelId)
        );

      // Admin can allocate/update resident assignment details
      allow update: if isAdmin()
        && request.resource.data.adminId == request.auth.uid
        && request.resource.data.isAllocated == true
        && request.resource.data.allocationDetails != null
        && request.resource.data.hostelId != null
        && isHostelAdmin(request.resource.data.hostelId);

      // ✅ Resident can READ their own resident record (by uid)
      allow read: if isSignedIn()
        && resource.data.uid == request.auth.uid;

      // ✅ Signed-in user can read INVITED residents matching their email
      // This enables the signup query: where('email', ==, authEmail).where('status', ==, 'invited')
      // The query MUST include status=='invited' filter for this rule to allow access
      allow read: if isSignedIn()
        && resource.data.status == 'invited'
        && resource.data.email == request.auth.token.email;

      // ✅ Resident can LINK invite during signup (update unclaimed invite)
      allow update: if isSignedIn()
        && resource.data.uid == null
        && resource.data.status == 'invited'
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'registered'
        && request.resource.data.isAllocated == false
        && request.resource.data.adminId == resource.data.adminId
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(['uid', 'status', 'name', 'fullName', 'phone']);
    }

    /* ───────── COMPLAINTS ───────── */

    match /complaints/{complaintId} {
      allow create: if isSignedIn() && isSelf(request.resource.data);
      allow read, update, delete: if isAdminOwner(resource.data)
        || isOwner(resource.data)
        || isSelf(resource.data);
    }

    /* ───────── PAYMENTS ───────── */

    match /payments/{paymentId} {
      allow create, update, delete: if isAdminOwner(request.resource.data);
      allow read: if isAdminOwner(resource.data)
        || isOwner(resource.data)
        || isSelf(resource.data);
    }
  }
}
